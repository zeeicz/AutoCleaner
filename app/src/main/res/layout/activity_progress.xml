<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvProgressIndex"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Proses 0/0"
        android:textSize="18sp"
        android:textColor="#888888" />

    <ImageView
        android:id="@+id/ivCurrentAppIcon"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="20dp"
        android:src="@android:drawable/sym_def_app_icon" />

    <TextView
        android:id="@+id/tvCurrentAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Nama Aplikasi"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="#000000"
        android:textAlignment="center" />

    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:id="@+id/pbLinear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:indeterminate="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Tekan BATAL untuk membatalkan proses"
        android:textColor="#FF0000"
        android:textStyle="bold"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnCancelOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="BATAL"
        android:backgroundTint="#FF0000"
        android:textColor="#FFFFFF" />

</LinearLayout>